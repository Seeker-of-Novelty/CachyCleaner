# ═══════════════════════════════════════════════════════════════════════════════
#  OPTION PARSING
# ═══════════════════════════════════════════════════════════════════════════════

set -l has_section 0

for arg in $argv
    switch $arg
        case -h --help
            _show_help
            exit 0
        case -n --dry-run
            set -g DRY_RUN 1
        case -b --basic
            set -g RUN_BASIC 1
            set has_section 1
        case -p --packages
            set -g RUN_PACKAGES 1
            set has_section 1
        case -c --containers
            set -g RUN_CONTAINERS 1
            set has_section 1
        case -j --junk
            set -g RUN_JUNK 1
            set has_section 1
        case -d --developers
            set -g RUN_DEVELOPERS 1
            set has_section 1
        case -k --broken
            set -g RUN_BROKEN 1
            set has_section 1
        case -l --list
            set -g LIST_MATCHES 1
        case -a --auto
            set -g AUTO_YES 1
        case -g --aggressive
            set -g AGGRESSIVE 1
        case -r --report
            set -g REPORT_ONLY 1
        case --no-age --nuke
            set -g NO_AGE 1
        case --paste
            set -g PASTE_OUTPUT 1
        case --all
            set -g RUN_BASIC 1
            set -g RUN_PACKAGES 1
            set -g RUN_CONTAINERS 1
            set -g RUN_JUNK 1
            set -g RUN_DEVELOPERS 1
            set -g RUN_BROKEN 1
            set has_section 1
        case '*'
            _error "Unknown option: $arg"
            _show_help
            exit 1
    end
end

# Default sections if none specified
if test $has_section -eq 0
    set -g RUN_BASIC 1
    set -g RUN_CONTAINERS 1
    set -g RUN_PACKAGES 1
end

# Report mode implies dry-run and no listing
if test $REPORT_ONLY -eq 1
    set -g DRY_RUN 1
    set -g LIST_MATCHES 0
end

# Cannot combine auto + dry-run
if test $AUTO_YES -eq 1 -a $DRY_RUN -eq 1
    _error "Cannot combine --auto and --dry-run."
    exit 1
end

# --no-age: override age threshold to 0 (match everything)
if test $NO_AGE -eq 1
    set -g AGE_DAYS 0
    set -g AGE_ARGS
    set -g AGE_LABEL "(all ages)"
else
    set -g AGE_ARGS -mtime +$AGE_DAYS
    set -g AGE_LABEL "older than $AGE_DAYS days"
end

# --paste: validate paste-cachyos and curl are available, set up log file
# --paste: validate curl is available
if test $PASTE_OUTPUT -eq 1
    if not command -q curl
        _error "Cannot use --paste: curl is not installed."
        exit 1
    end
end

# ═══════════════════════════════════════════════════════════════════════════════
#  PASTE HELPER — wraps the entire run to capture output for paste.cachyos.org
# ═══════════════════════════════════════════════════════════════════════════════

# If --paste is active and we are NOT already inside the tee wrapper,
# re-exec ourselves through tee so everything (stdout + stderr) is captured.
# The tee'd copy goes to a temp file, then gets ANSI-stripped and uploaded.
if test $PASTE_OUTPUT -eq 1 -a -z "$_CACHYCLEANER_INSIDE_TEE"
    set -gx _CACHYCLEANER_INSIDE_TEE 1
    set -l raw_log (mktemp /tmp/cachycleaner-paste-XXXXXX.raw)

    # Re-run with tee capturing everything (colours stay on terminal)
    fish (status filename) $argv 2>&1 | tee $raw_log
    set -l run_exit $pipestatus[1]

    # Strip ANSI escape codes for a clean paste
    sed 's/\x1b\[[0-9;]*m//g' $raw_log >$raw_log.clean

    # Upload to paste.cachyos.org
    set -l paste_url "https://paste.cachyos.org"
    set -l response (curl -s --data-binary @$raw_log.clean --url $paste_url 2>/dev/null)
    if test -n "$response"
        echo ""
        echo (set_color --bold cyan)"Paste uploaded: $paste_url$response.txt"(set_color normal)
    else
        echo ""
        echo (set_color red)"Failed to upload paste (no response from $paste_url)."(set_color normal)
    end

    # Clean up temp files
    rm -f $raw_log $raw_log.clean 2>/dev/null
    exit $run_exit
end

# ═══════════════════════════════════════════════════════════════════════════════
#  BANNER
# ═══════════════════════════════════════════════════════════════════════════════

echo ""
echo "$C_BOLD$SCRIPT_NAME $SCRIPT_VERSION$C_RESET"
if set -q _warn_config_migration
    _warn "$_warn_config_migration"
end
if test $NO_AGE -eq 1
    _warn "Age filter: DISABLED — all eligible files will be matched regardless of age"
    if test $DRY_RUN -eq 0 -a $REPORT_ONLY -eq 0
        _warn "This is destructive! Consider running with --dry-run first."
        echo ""
        read -P "$C_YELLOW""Continue without age filter? (type YES to confirm): $C_RESET" _nuke_confirm
        if test "$_nuke_confirm" != "YES"
            echo "Aborted."
            exit 0
        end
    end
else
    _note "Age threshold: files $AGE_LABEL"
end
if test $AGGRESSIVE -eq 1
    _note "Mode: aggressive"
else
    _note "Mode: normal"
end
_note "Personal folders (Downloads/Documents/Desktop/...) are never targeted."

if test $REPORT_ONLY -eq 1
    _warn "[REPORT ONLY] No prompts, no deletions."
else if test $DRY_RUN -eq 1
    _warn "[DRY RUN] Nothing will be deleted."
end

