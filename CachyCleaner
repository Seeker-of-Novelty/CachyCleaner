## Python __pycache__ ##

_mc_pycache() {
    local _pyc_size
    _pyc_size=$(find ~ -maxdepth 6 -type d -name "__pycache__" -exec du -scb {} + 2>/dev/null | tail -n1) || true
    _pyc_size=${_pyc_size//[^0-9]/}
    _pyc_size=${_pyc_size:-0}
    if [[ $_pyc_size -gt 0 ]]; then
        if _mc_prompt "\nClean Python __pycache__ directories in \$HOME (y/N)? "; then
            unset _mc_quicksums _mc_quicksums2 _mc_diff
            _mc_diff=$_pyc_size
            if [[ $_mc_dry_run -eq 0 ]]; then
                find ~ -maxdepth 6 -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
            fi
            _mc_bigdiff+=("$_mc_diff")
            echo -e "\033[0;32mDone\033[0m"
            _mc_bytcon "$_mc_diff"
        else
            echo -e "\033[0;90mSkipped\033[0m"
        fi
    fi
}

