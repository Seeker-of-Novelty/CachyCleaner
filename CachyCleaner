function _clean_rotated_logs
    _ensure_sudo

    # Build the find command as an argument list to avoid Fish glob expansion.
    # Fish expands *.old etc. against CWD; we must quote them for find.
    set -l find_cmd
    if test $DRY_RUN -eq 1
        set find_cmd find
    else
        set find_cmd sudo find
    end

    set -l name_args \
        -type f '(' \
        -name '*.old' -o \
        -name '*.gz' -o \
        -name '*.xz' -o \
        -name '*.bz2' -o \
        -name '*.[1-9]' -o \
        -name '*.[1-9].gz' \
        ')' $AGE_ARGS

    set -l count (command $find_cmd /var/log $name_args 2>/dev/null | wc -l | string trim)
    set -l bytes (command $find_cmd /var/log $name_args -printf '%s\n' 2>/dev/null | awk '{s+=$1} END{printf "%d", s+0}')
    test -z "$bytes"; and set bytes 0
    test $count -gt 0; or return

    _print_preview "/var/log rotated logs $AGE_LABEL" $count $bytes

    if test $LIST_MATCHES -eq 1
        command $find_cmd /var/log $name_args -print 2>/dev/null
    end

    if _confirm "Delete rotated logs $AGE_LABEL from /var/log (y/N)? "
        if test $DRY_RUN -eq 1
            _note "Would remove old rotated logs from /var/log"
        else
            command sudo find /var/log $name_args -delete 2>/dev/null
            _ok
        end
        _add_total $bytes
    else
        _note "Skipped"
    end
end

