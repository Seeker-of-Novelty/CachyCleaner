_mc_pacmanfuncts() {
    ## Check for pacman before operations below ##
    if command -v pacman >/dev/null 2>&1; then

        _mc_aurhelpers

        _mc_pacmanunused

        _mc_pacmancache

        _mc_orphans

        _mc_pacmancrumbs

    fi
}

## ==================== ##
## Option Processing     ##
## ==================== ##

## Default All ##

if [[ "$#" == 0 ]]; then
    set -- -bcdp
elif [[ "$#" -eq 1 && "$1" == "-n" ]]; then
    set -- -nbcdp
fi

## Dry Run Banner ##

if [[ $_mc_dry_run -eq 1 ]]; then
    echo -e "\n\033[0;33m[DRY RUN] Simulating cleanings — nothing will be modified or deleted."
    echo -e "Sizes shown are estimates (upper bounds).\033[0m"
fi

## Process Options ##

while getopts ":abcdjphn" option; do
    case $option in
        a) # automatic mode
            if [[ $_mc_dry_run -eq 1 ]]; then
                echo -e "\nError: -a (auto) and -n (dry-run) cannot be combined. Use -n alone."
                exit 1
            fi
            sudo -k
            echo -e "\nPerforming all cleanings automatically."
            echo -e "\nThis is the final warning.\n"
            if sudo -p "To continue enter the password for %p (ctrl+c to cancel): " true; then
                echo ""
                yes | $0 ;
            fi
            exit ;;
        b) # clean basics
            _mc_section "Basic Cleanup"
            _mc_junker
            _mc_trash
            _mc_homecache
            _mc_thumbcache
            _mc_mesashader
            _mc_crashdumps
            _mc_xsessionerrs
            _mc_journlogs
            _mc_rotatedlogs
            _mc_coredumps
            _mc_oldvartmp
            ;;
        c) # clean containers
            _mc_section "Containers"
            _mc_confuncts
            ;;
        d) # clean devs
            _mc_section "Developer Caches"
            _mc_devfuncts
            ;;
        j) # clean junk
            _mc_section "Junk Directories"
            _mc_junker
            ;;
        p) # clean pkg-related
            _mc_section "Package Management"
            _mc_pkgfiledata
            _mc_packagekitdata
            _mc_pamacdata
            _mc_pacmanfuncts
            ;;
        n) # dry-run (already processed in pre-scan)
            ;;
        h) # display Help
            _mc_help
            exit ;;
        \?) # invalid option
            echo "Error: Invalid option"
            _mc_help
            exit ;;
    esac
done

## Show Total ##

_mc_section "Summary"
_mc_calcttl

## Exit Script ##

if [[ $_mc_dry_run -eq 1 ]]; then
    echo -e "\n\033[0;33m[DRY RUN] No changes were made.\033[0m\n"
else
    echo -ne "\nPress any key to exit."
    read -t60 -s -n1
    echo -e "\n"
fi
exit 0
