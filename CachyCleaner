        set total_bytes (math "$total_bytes + $stats[2]")
    end

    # __pycache__ directories under $HOME
    set -l prune_args "-path $HOME/.local/share/Trash -o -path $HOME/.steam -o -path $HOME/.cache -o -path $HOME/.cargo -o -path $HOME/go"
    set -l pyc_count (command find $HOME '(' -path "$HOME/.local/share/Trash" -o -path "$HOME/.steam" -o -path "$HOME/.cache" -o -path "$HOME/.cargo" -o -path "$HOME/go" ')' -prune -o -type d -name __pycache__ $AGE_ARGS -print 2>/dev/null | wc -l | string trim)
