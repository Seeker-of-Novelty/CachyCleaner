    set -l count (command $find_cmd "$dir" -maxdepth 1 -type d -name 'download-*' $AGE_ARGS 2>/dev/null | wc -l | string trim)
    test $count -gt 0; or return
    set -l bytes (command $find_cmd "$dir" -maxdepth 1 -type d -name 'download-*' $AGE_ARGS -exec du -sb -- '{}' + 2>/dev/null | awk '{s+=$1} END{printf "%d", s+0}')
    test -z "$bytes"; and set bytes 0

    _print_preview "Pacman interrupted downloads $AGE_LABEL" $count $bytes

    if _confirm "Delete old pacman interrupted-download directories (y/N)? "
        if test $DRY_RUN -eq 1
            _note "Would remove old pacman interrupted-download directories"
        else
            command sudo find "$dir" -maxdepth 1 -type d -name 'download-*' $AGE_ARGS -exec rm -rf -- '{}' + 2>/dev/null
            _ok
        end
        _add_total $bytes
    else
        _note "Skipped"
    end
end

function _clean_orphans
    set -g TOOL_WORK 1
    command -q pacman; or return

    set -l orphans (pacman -Qdtq 2>/dev/null)
    test (count $orphans) -gt 0; or return

    _note "Orphan package removal is not age-based. Review carefully."
    echo "$C_BOLD""Orphan packages found:$C_RESET"
    for pkg in $orphans
        echo "  $pkg"
    end

    set -l total_size 0
    for pkg in $orphans
        set -l info (pacman -Qi -- $pkg 2>/dev/null)
        for line in $info
            if string match -q 'Installed Size*' $line
                set -l size (echo $line | awk '{print $4}')
                set -l unit (echo $line | awk '{print $5}')
                switch $unit
                    case KiB
                        set total_size (math "$total_size + "(math --scale=0 "$size * 1024"))
                    case MiB
                        set total_size (math "$total_size + "(math --scale=0 "$size * 1048576"))
                    case GiB
                        set total_size (math "$total_size + "(math --scale=0 "$size * 1073741824"))
                end
            end
        end
    end

    _print_preview "Orphan packages" (count $orphans) $total_size

    if _confirm "Remove all orphan packages shown above (y/N)? "
        if test $DRY_RUN -eq 1
            _note "Would remove the orphan packages listed above"
        else
            _ensure_sudo
            echo ""
            sudo pacman -Rns --noconfirm -- $orphans
            _ok
        end
    else
        _note "Skipped"
    end
end

function _clean_pacnew_pacsave
    command -q pacdiff; or return
    set -l files (pacdiff -o 2>/dev/null)
    test (count $files) -gt 0; or return

    echo ""
    _warn "Attention! Manual intervention required for the following pacnew/pacsave files:"
    for f in $files
        echo "  $f"
    end
    _note "Run 'sudo pacdiff' to review and merge these files."
end

