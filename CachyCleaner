                    fi
                else
                    echo -e "\033[0;90mSkipped\033[0m\n"
                fi
            fi
            if [[ $_mc_dry_run -eq 0 ]]; then
                go clean -cache
                _mc_calcsec ~/go/pkg >/dev/null 2>&1
