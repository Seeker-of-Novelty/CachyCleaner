## Pacman Orphans ##

_mc_orphans() {
    if [[ $(pacman -Qdtq | head -c1 | wc -c) != 0 ]]; then
        if _mc_prompt "\nClean out all orphan packages (y/N)? "; then
            echo -ne "\nThe following will be uninstalled:\n$(pacman -Qdtq | pacman -Rsp -)\n"

            if _mc_prompt "\nContinue with removal (y/N)? "; then
                unset _mc_diff _mc_quicksums _mc_quicksums2
                if [[ $_mc_dry_run -eq 0 ]]; then
                    read -r _mc_diff < <(pacman -Qdtq | LANG=C sudo pacman -Rns --noconfirm - | tee | awk '/Total Removed/ { print int($4*1048576) }') || EXIT_CODE=$? ;
                else
                    _mc_diff=$(pacman -Qdtq | xargs -r pacman -Qi 2>/dev/null | awk '/^Installed Size/ {
                        size = $4; unit = $5
                        if (unit ~ /KiB/) size *= 1024
                        else if (unit ~ /MiB/) size *= 1048576
                        else if (unit ~ /GiB/) size *= 1073741824
                        total += size
                    } END { printf "%d", total + 0 }') || _mc_diff=0
                fi
                echo -e "\033[0;32mDone\033[0m"
                _mc_calcdif
            else
                echo -e "\033[0;90mSkipped\033[0m"
            fi
        else
            echo -e "\033[0;90mSkipped\033[0m"
        fi
    fi
}

## Pacman Crumbs ##

_mc_pacmancrumbs() {
    if compgen -G "/var/cache/pacman/pkg/download-*" >/dev/null 2>&1 && [[ ! -e /var/lib/pacman/db.lck ]]; then
        if _mc_prompt "\nClean out pacman sandbox and interrupted download directories (y/N)? "; then
            echo -ne "\nThe following will be deleted:\n$(find /var/cache/pacman/pkg/ -maxdepth 1 -type d ! -name '*.*' -name "download-*")\n"

            if _mc_prompt "\nContinue with removal (y/N)? "; then
                unset _mc_quicksums _mc_quicksums2 _mc_diff
                _mc_diff=$(du -scb /var/cache/pacman/pkg/download-* 2>/dev/null | tail -n1)
                _mc_diff=${_mc_diff//[^0-9]/}
