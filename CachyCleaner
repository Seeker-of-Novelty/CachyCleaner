# ═══════════════════════════════════════════════════════════════════════════════
#  BROKEN SYMLINK FINDER (deep system scan)
# ═══════════════════════════════════════════════════════════════════════════════

function _clean_broken_symlinks
    _note "Scanning \$HOME for broken symlinks (this may take a moment)..."
    _note "Excluding: Steam runtime, Flatpak sandboxes, browser singletons, Trash, .cache"

    set -l broken_links (command find $HOME -xtype l \
        -not -path "$HOME/.local/share/Trash/*" \
        -not -path "$HOME/.local/share/Steam/*" \
        -not -path "$HOME/.steam/*" \
        -not -path "$HOME/.cache/*" \
        -not -path "$HOME/.var/app/*" \
        -not -path "$HOME/.zoom/*" \
        -not -name 'SingletonLock' \
        -not -name 'SingletonCookie' \
        -not -name 'SingletonSocket' \
        2>/dev/null)

    set -l count (count $broken_links)
    if test $count -eq 0
        _note "No broken symlinks found."
        return
    end

    set -l total_bytes 0
    echo "$C_BOLD""Found $count broken symlink(s):$C_RESET"

    if test $LIST_MATCHES -eq 1; or test $count -le 20
        for link in $broken_links
            set -l target (readlink -- "$link" 2>/dev/null; or echo "???")
            printf '  %s → %s (broken)\n' "$link" "$target"
        end
    else
        # Show first 10 and last 5
        for i in (seq 1 10)
            set -l link $broken_links[$i]
            set -l target (readlink -- "$link" 2>/dev/null; or echo "???")
            printf '  %s → %s (broken)\n' "$link" "$target"
        end
        echo "  ... and "(math "$count - 15")" more ..."
        for i in (seq (math "$count - 4") $count)
            set -l link $broken_links[$i]
            set -l target (readlink -- "$link" 2>/dev/null; or echo "???")
            printf '  %s → %s (broken)\n' "$link" "$target"
        end
    end

    if _confirm "Remove all $count broken symlink(s) (y/N)? "
        if test $DRY_RUN -eq 1
            _note "Would remove $count broken symlinks"
        else
            for link in $broken_links
                rm -f -- "$link" 2>/dev/null
            end
            _ok
        end
    else
        _note "Skipped"
    end
end

