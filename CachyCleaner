# ═══════════════════════════════════════════════════════════════════════════════
#  SUMMARY
# ═══════════════════════════════════════════════════════════════════════════════

_print_ranked_report

_section "Summary"

if test $DRY_RUN -eq 1
    printf 'Direct-file cleanup would free about: %s\n' (_human_bytes $TOTAL_BYTES)
else
    printf 'Direct-file cleanup freed about: %s\n' (_human_bytes $TOTAL_BYTES)
end

if test $TOOL_WORK -eq 1
    _note "Some tool-driven actions (paccache / journalctl / flatpak / pacman orphans) report their own effect and are not included in the total above."
end

if test $REPORT_ONLY -eq 1
    _warn "[REPORT ONLY] No changes were made."
else if test $DRY_RUN -eq 1
    _warn "[DRY RUN] No changes were made."
end

echo ""
exit $EXIT_CODE
