#!/usr/bin/env fish
#
# CachyCleaner for Fish Shell
# Version: 4.0
#
# A safe, thorough system cleaner for CachyOS / Arch Linux.
# Designed to run interactively in Konsole (or any terminal).
#
# Inspired by maclean (cscs).
# Rewritten from scratch for the Fish shell.
#
# Safety rules:
#   - Never touches Downloads, Documents, Desktop, Pictures, Music, Videos, etc.
#   - Dry-run mode simulates everything without deleting a single file.
#   - Age-based cleanup defaults to files older than 3 days.
#   - Broken symlinks are detected and offered for removal.
#   - Every action is explained and requires confirmation (unless --auto).
#
# Usage:
#   cachycleaner.fish [options]
#
#   Options:
#     -h / --help          Show this help
#     -n / --dry-run       Simulate only — nothing is deleted
#     -b / --basic         Run basic cleanup (cache, trash, logs, crash dumps)
#     -p / --packages      Run package management cleanup
#     -c / --containers    Run container cleanup (Flatpak, Snap)
#     -j / --junk          Run custom junk directory cleanup
#     -d / --developers    Run developer cache cleanup
#     -k / --broken        Find and remove broken symlinks in $HOME
#     -l / --list          List matched files before each prompt
#     -a / --auto          Auto-confirm all prompts (cannot combine with --dry-run)
#     -g / --aggressive    Aggressive mode (GPU caches, Steam shaders, etc.)
#     -r / --report        Report-only mode (scan and show sizes, no prompts)
#     --no-age / --nuke    Remove the age filter — clean ALL eligible files
#     --paste              Upload output to paste.cachyos.org and print link
#     --all                Run every section (basic + packages + containers + junk + dev + broken)
#
#   Defaults:
#     No options     => runs --basic --packages --containers
#     Only --dry-run => runs dry-run of --basic --packages --containers
#
#   Config file:
#     ~/.config/cachycleaner/cachycleaner.conf
#
#   Examples:
#     cachycleaner.fish --dry-run --list     # preview with file listing
#     cachycleaner.fish -d -n                # preview developer cache cleanup
#     cachycleaner.fish --all --dry-run      # preview everything
#     cachycleaner.fish -r --paste           # report and share via paste.cachyos.org
#

# ═══════════════════════════════════════════════════════════════════════════════
#  GLOBAL STATE
# ═══════════════════════════════════════════════════════════════════════════════

set -g SCRIPT_NAME    "CachyCleaner"
set -g SCRIPT_VERSION "4.0"
set -g DEFAULT_AGE_DAYS 3
set -g DEFAULT_KEEP_VERSIONS 2

set -g DRY_RUN       0
set -g AUTO_YES      0
set -g LIST_MATCHES  0
set -g REPORT_ONLY   0
set -g AGGRESSIVE    0
set -g NO_AGE        0
set -g PASTE_OUTPUT  0

set -g RUN_BASIC      0
set -g RUN_PACKAGES   0
set -g RUN_CONTAINERS 0
set -g RUN_JUNK       0
set -g RUN_DEVELOPERS 0
set -g RUN_BROKEN     0

set -g TOTAL_BYTES   0
set -g SUDO_READY    0
set -g TOOL_WORK     0
set -g EXIT_CODE     0

set -g AGE_DAYS          $DEFAULT_AGE_DAYS
set -g KEEP_VERSIONS     $DEFAULT_KEEP_VERSIONS
set -g REPORT_ROWS

# ═══════════════════════════════════════════════════════════════════════════════
#  REFUSE ROOT
# ═══════════════════════════════════════════════════════════════════════════════

if test (id -u) -eq 0
    echo ""
    echo "Please run $SCRIPT_NAME as your normal user, not as root."
    echo ""
    exit 1
end

# ═══════════════════════════════════════════════════════════════════════════════
#  CONFIG FILE
# ═══════════════════════════════════════════════════════════════════════════════

set -g CONFIG_DIR (set -q XDG_CONFIG_HOME; and echo $XDG_CONFIG_HOME; or echo $HOME/.config)/cachycleaner
set -g CONFIG_FILE $CONFIG_DIR/cachycleaner.conf

mkdir -p $CONFIG_DIR

if not test -f $CONFIG_FILE
    # Write default config
    echo '# CachyCleaner config (fish version)
#
# AGE_DAYS: files older than this many days are eligible for cleanup.
# KEEP_VERSIONS: how many pacman package versions to keep.
#
# JUNK_DIRS: directories whose contents (older than AGE_DAYS) may be removed.
#   Must be under $HOME; personal dirs like Downloads are blocked.
#
# PROTECTED_CACHE_DIRS: top-level paths under ~/.cache to never touch.

set -g AGE_DAYS 3
set -g KEEP_VERSIONS 2

set -g JUNK_DIRS \\
    ~/.adobe \\
    ~/.macromedia

set -g PROTECTED_CACHE_DIRS
' >$CONFIG_FILE
end

# Detect and migrate legacy bash-style config
if test -f $CONFIG_FILE
    if grep -q '=' $CONFIG_FILE 2>/dev/null; and not grep -q '^set ' $CONFIG_FILE 2>/dev/null
        set -l old_config $CONFIG_FILE.bak.(date +%s)
        cp $CONFIG_FILE $old_config
        set -g _warn_config_migration "Config was in bash format — backed up to $old_config and regenerated."
        # Parse legacy values before overwriting
        set -l _legacy_age (grep -oP '(?<=CLEAN_AGE_DAYS=)\d+' $CONFIG_FILE 2>/dev/null)
        set -l _legacy_keep (grep -oP '(?<=KEEP_PACMAN_VERSIONS=)\d+' $CONFIG_FILE 2>/dev/null)
        # Regenerate in fish syntax
        echo '# CachyCleaner config (fish version)
#
# AGE_DAYS: files older than this many days are eligible for cleanup.
# KEEP_VERSIONS: how many pacman package versions to keep.
#
# JUNK_DIRS: directories whose contents (older than AGE_DAYS) may be removed.
#   Must be under $HOME; personal dirs like Downloads are blocked.
#
# PROTECTED_CACHE_DIRS: top-level paths under ~/.cache to never touch.

set -g AGE_DAYS '(test -n "$_legacy_age"; and echo $_legacy_age; or echo 3)'
set -g KEEP_VERSIONS '(test -n "$_legacy_keep"; and echo $_legacy_keep; or echo 2)'

set -g JUNK_DIRS \\
    ~/.adobe \\
    ~/.macromedia

set -g PROTECTED_CACHE_DIRS
' >$CONFIG_FILE
    end
end

source $CONFIG_FILE 2>/dev/null

# Apply defaults for anything the config didn't set
set -q AGE_DAYS;      or set -g AGE_DAYS $DEFAULT_AGE_DAYS
set -q KEEP_VERSIONS; or set -g KEEP_VERSIONS $DEFAULT_KEEP_VERSIONS
set -q JUNK_DIRS;     or set -g JUNK_DIRS
set -q PROTECTED_CACHE_DIRS; or set -g PROTECTED_CACHE_DIRS

# ═══════════════════════════════════════════════════════════════════════════════
#  UI HELPERS (colour output for Konsole / any terminal)
# ═══════════════════════════════════════════════════════════════════════════════

set -g C_RESET  (set_color normal)
set -g C_DIM    (set_color brblack)
set -g C_GREEN  (set_color green)
set -g C_YELLOW (set_color yellow)
set -g C_RED    (set_color red)
set -g C_CYAN   (set_color --bold cyan)
set -g C_BOLD   (set_color --bold white)

function _section --description "Print a section header"
    echo ""
    echo "$C_CYAN── $argv[1] ──$C_RESET"
end

function _note --description "Print a dim info line"
    echo "$C_DIM$argv[1]$C_RESET"
end

function _warn --description "Print a yellow warning"
    echo "$C_YELLOW$argv[1]$C_RESET"
end

function _error --description "Print a red error"
    echo "$C_RED$argv[1]$C_RESET"
end

function _ok --description "Print a green Done"
    echo ""
    echo "$C_GREEN""Done$C_RESET"
end

# ═══════════════════════════════════════════════════════════════════════════════
#  BYTE FORMATTING
# ═══════════════════════════════════════════════════════════════════════════════

function _human_bytes --description "Convert bytes to human-readable"
    set -l b (math --scale=0 "$argv[1]" 2>/dev/null; or echo 0)
    if test $b -lt 1024
        printf '%d B' $b
    else if test $b -lt 1048576
        printf '%d KiB' (math --scale=0 "$b / 1024")
    else if test $b -lt 1073741824
        printf '%d MiB' (math --scale=0 "$b / 1048576")
    else
        printf '%.2f GiB' (math "$b / 1073741824")
    end
end

function _add_total --description "Accumulate freed bytes"
    set -g TOTAL_BYTES (math "$TOTAL_BYTES + $argv[1]")
end

function _add_report_row --description "Store a label|bytes row for the ranked report"
    set -a REPORT_ROWS "$argv[2]|$argv[1]"
end

function _print_ranked_report
    test (count $REPORT_ROWS) -eq 0; and return
    _section 'Ranked Cleanup Opportunities'
    # Sort descending by byte value
    for row in (printf '%s\n' $REPORT_ROWS | sort -t'|' -nr -k1,1)
        set -l parts (string split '|' $row)
        printf '  %-48s %s\n' "$parts[2]" (_human_bytes $parts[1])
    end
    echo ""
end

# ═══════════════════════════════════════════════════════════════════════════════
#  CONFIRMATION & SUDO
# ═══════════════════════════════════════════════════════════════════════════════

function _confirm --description "Ask the user y/N; respects DRY_RUN, AUTO_YES, REPORT_ONLY"
    set -l prompt $argv[1]

    if test $REPORT_ONLY -eq 1
        return 1
    end

    if test $AUTO_YES -eq 1
        printf '%s%sy (auto)%s\n' "$prompt" "$C_GREEN" "$C_RESET"
        return 0
    end

    if test $DRY_RUN -eq 1
        printf '%s%sy (dry run)%s\n' "$prompt" "$C_YELLOW" "$C_RESET"
        return 0
    end

    read -P "$prompt" reply
    switch (string lower "$reply")
        case y yes
            return 0
        case '*'
            return 1
    end
end

function _ensure_sudo --description "Cache sudo credentials (skip in dry-run)"
    if test $SUDO_READY -eq 1; or test $DRY_RUN -eq 1
        return 0
    end
    sudo -v
    set -g SUDO_READY 1
end

# ═══════════════════════════════════════════════════════════════════════════════
#  PATH SAFETY CHECKS
# ═══════════════════════════════════════════════════════════════════════════════

set -g FORBIDDEN_PATHS \
    $HOME/Downloads \
    $HOME/Documents \
    $HOME/Desktop \
    $HOME/Pictures \
    $HOME/Music \
    $HOME/Videos \
    $HOME/Public \
    $HOME/Templates

function _is_forbidden --description "Return 0 if path is under a personal dir"
    set -l target (realpath -m -- $argv[1] 2>/dev/null; or echo $argv[1])
    for fp in $FORBIDDEN_PATHS
        set -l base (realpath -m -- $fp 2>/dev/null; or echo $fp)
        if test "$target" = "$base"; or string match -q "$base/*" "$target"
            return 0
        end
    end
    return 1
end

function _is_protected_cache --description "Return 0 if path is user-protected"
    set -l candidate (realpath -m -- $argv[1] 2>/dev/null; or echo $argv[1])
    for p in $PROTECTED_CACHE_DIRS
        set -l expanded (string replace '~' $HOME $p)
        set -l resolved (realpath -m -- $expanded 2>/dev/null; or echo $expanded)
        if test "$candidate" = "$resolved"; or string match -q "$resolved/*" "$candidate"
            return 0
        end
    end
    return 1
end

function _is_safe_junk_dir --description "Validate a custom junk dir is under HOME and not a sensitive root"
    set -l target (realpath -m -- $argv[1] 2>/dev/null; or echo $argv[1])
    set -l home_root (realpath -m -- $HOME 2>/dev/null; or echo $HOME)

    # Must be under $HOME
    string match -q "$home_root/*" "$target"; or return 1
    test "$target" != "$home_root"; or return 1

    # Block sensitive directories
    set -l blocked \
        $home_root/.config \
        $home_root/.local \
        $home_root/.ssh \
        $home_root/.gnupg \
        $home_root/.mozilla \
        $home_root/.steam \
        $home_root/.var/app

    for root in $blocked
        set -l r (realpath -m -- $root 2>/dev/null; or echo $root)
        if test "$target" = "$r"; or string match -q "$r/*" "$target"
            return 1
        end
    end
    return 0
end

# ═══════════════════════════════════════════════════════════════════════════════
#  GENERIC FIND HELPERS
# ═══════════════════════════════════════════════════════════════════════════════

function _age_filter --description "Return -mtime +N args, or nothing if NO_AGE is set"
    if test $NO_AGE -eq 1
        # Return nothing — no age filter applied
        return
    end
    echo "-mtime"
    echo "+$AGE_DAYS"
end

# This global will be populated after option parsing (see below)
set -g AGE_ARGS

function _count_and_bytes_older --description "Count items and total bytes for files older than AGE_DAYS in a dir"
    # Usage: _count_and_bytes_older /path
    # Prints two lines: count, bytes
    set -l dir $argv[1]
    if not test -d "$dir"
        echo 0
        echo 0
        return
    end
    set -l count 0
    set -l bytes 0
    for entry in (command find "$dir" -mindepth 1 -maxdepth 1 $AGE_ARGS 2>/dev/null)
        set count (math "$count + 1")
        set -l sz (du -sb -- "$entry" 2>/dev/null | awk '{print $1+0}')
        set bytes (math "$bytes + $sz")
    end
    echo $count
    echo $bytes
end

function _count_and_bytes_deep_older --description "Count files/links/empty-dirs older than AGE_DAYS (recursive)"
    set -l dir $argv[1]
    if not test -e "$dir"
        echo 0
        echo 0
        return
    end
    set -l count 0
    set -l bytes 0
    # Files and links
    set -l n (command find "$dir" -mindepth 1 '(' -type f -o -type l ')' $AGE_ARGS 2>/dev/null | wc -l | string trim)
    set count (math "$count + $n")
    # Empty dirs
    set n (command find "$dir" -mindepth 1 -type d -empty $AGE_ARGS 2>/dev/null | wc -l | string trim)
    set count (math "$count + $n")
    # Byte sum
    set bytes (command find "$dir" -mindepth 1 -type f $AGE_ARGS -printf '%s\n' 2>/dev/null | awk '{s+=$1} END{printf "%d", s+0}')
    test -z "$bytes"; and set bytes 0
    echo $count
    echo $bytes
end

function _count_and_bytes_deep_system --description "Like _count_and_bytes_deep_older but uses sudo"
    set -l dir $argv[1]
    if not test -e "$dir"
        echo 0
        echo 0
        return
    end
    set -l find_cmd
    if test $DRY_RUN -eq 1
        set find_cmd find
    else
        set find_cmd sudo find
    end
    set -l count 0
    set -l bytes 0
    set -l n (command $find_cmd "$dir" -mindepth 1 '(' -type f -o -type l ')' $AGE_ARGS 2>/dev/null | wc -l | string trim)
    set count (math "$count + $n")
    set n (command $find_cmd "$dir" -mindepth 1 -type d -empty $AGE_ARGS 2>/dev/null | wc -l | string trim)
    set count (math "$count + $n")
    set bytes (command $find_cmd "$dir" -mindepth 1 -type f $AGE_ARGS -printf '%s\n' 2>/dev/null | awk '{s+=$1} END{printf "%d", s+0}')
    test -z "$bytes"; and set bytes 0
    echo $count
    echo $bytes
end

function _remove_old_files --description "Delete old files/links/empty-dirs from a user dir"
    set -l dir $argv[1]
    test -e "$dir"; or return
    command find "$dir" -mindepth 1 '(' -type f -o -type l ')' $AGE_ARGS -delete 2>/dev/null
    command find "$dir" -mindepth 1 -type d -empty $AGE_ARGS -delete 2>/dev/null
end

function _remove_old_system_files --description "Delete old files/links/empty-dirs from a system dir (sudo)"
    set -l dir $argv[1]
    test -e "$dir"; or return
    command sudo find "$dir" -mindepth 1 '(' -type f -o -type l ')' $AGE_ARGS -delete 2>/dev/null
    command sudo find "$dir" -mindepth 1 -type d -empty $AGE_ARGS -delete 2>/dev/null
end

function _print_preview --description "Show item count and size for a cleanup target"
    set -l label $argv[1]
    set -l count $argv[2]
    set -l bytes $argv[3]
    if test $count -eq 0
        _note "$label: nothing eligible"
    else
        echo "$C_DIM$label$C_RESET: $count item(s), "(_human_bytes $bytes)
        _add_report_row "$label" "$bytes"
    end
end

# ═══════════════════════════════════════════════════════════════════════════════
#  GENERIC MULTI-DIR CLEANER
# ═══════════════════════════════════════════════════════════════════════════════

function _clean_user_dirs --description "Clean old files from one or more user directories"
    # Usage: _clean_user_dirs "Label" "Prompt (y/N)? " dir1 [dir2 ...]
    set -l label $argv[1]
    set -l prompt $argv[2]
    set -l dirs $argv[3..]

    set -l total_count 0
    set -l total_bytes 0

    for dir in $dirs
        test -e "$dir"; or continue
        set -l stats (_count_and_bytes_deep_older "$dir")
        set total_count (math "$total_count + $stats[1]")
        set total_bytes (math "$total_bytes + $stats[2]")
    end

    test $total_count -gt 0; or return

    _print_preview "$label" $total_count $total_bytes

    if test $LIST_MATCHES -eq 1
        for dir in $dirs
            test -e "$dir"; or continue
            command find "$dir" -mindepth 1 '(' -type f -o -type l ')' $AGE_ARGS -print 2>/dev/null
            command find "$dir" -mindepth 1 -type d -empty $AGE_ARGS -print 2>/dev/null
        end
    end

    if _confirm "$prompt"
        if test $DRY_RUN -eq 1
            _note "Would remove eligible items from: $dirs"
        else
            for dir in $dirs
                test -e "$dir"; or continue
                _remove_old_files "$dir"
            end
            _ok
        end
        _add_total $total_bytes
    else
        _note "Skipped"
    end
end

# ═══════════════════════════════════════════════════════════════════════════════
#  REPORT: TOP SPACE HOGS
# ═══════════════════════════════════════════════════════════════════════════════

function _report_top_space_hogs
    _section 'Largest Likely Cleanup Targets'
    set -l targets \
        $HOME/.cache \
        $HOME/.local/share/Trash/files \
        /var/cache/pacman/pkg \
        /var/lib/flatpak \
        $HOME/.local/share/flatpak \
        $HOME/.local/share/Steam \
        $HOME/.steam/root

    set -l found 0
    for p in $targets
        test -e "$p"; or continue
        set -l resolved (realpath -e -- "$p" 2>/dev/null; or echo $p)
        set -l sz (du -shL -- "$resolved" 2>/dev/null | awk '{print $1}')
        test -z "$sz"; and continue
        printf '  %-40s %s\n' "$p" "$sz"
        set found 1
    end
    if test $found -eq 0
        _note "No reportable targets found."
    end
end

# ═══════════════════════════════════════════════════════════════════════════════
#  BASIC CLEANUP ACTIONS
# ═══════════════════════════════════════════════════════════════════════════════

function _clean_trash
    set -l trash_files $HOME/.local/share/Trash/files
    set -l trash_info $HOME/.local/share/Trash/info
    test -d "$trash_files"; or return

    set -l stats (_count_and_bytes_older "$trash_files")
    set -l count $stats[1]
    set -l bytes $stats[2]
    test $count -gt 0; or return

    _print_preview "User trash $AGE_LABEL" $count $bytes

    if test $LIST_MATCHES -eq 1
        command find "$trash_files" -mindepth 1 -maxdepth 1 $AGE_ARGS -print 2>/dev/null
    end

    if _confirm "Delete trash entries $AGE_LABEL (y/N)? "
        if test $DRY_RUN -eq 1
            _note "Would remove old trash entries"
        else
            for entry in (command find "$trash_files" -mindepth 1 -maxdepth 1 $AGE_ARGS -print0 2>/dev/null | string split0)
                set -l base (basename -- "$entry")
                rm -rf -- "$entry"
                rm -f -- "$trash_info/$base.trashinfo"
            end
            _ok
        end
        _add_total $bytes
    else
        _note "Skipped"
    end
end

function _clean_thumbnails
    _clean_user_dirs \
        "Thumbnail cache $AGE_LABEL" \
        "Delete thumbnail cache entries $AGE_LABEL (y/N)? " \
        $HOME/.cache/thumbnails
end

function _clean_generic_home_cache
    set -l root $HOME/.cache
    test -d "$root"; or return

    # Dirs to skip (handled separately or by other sections)
    set -l skip_names thumbnails mesa_shader_cache mesa_shader_cache_db yay paru pacaur pikaur trizen pamac

    set -l total_count 0
    set -l total_bytes 0

    for top in (command find "$root" -mindepth 1 -maxdepth 1 -print 2>/dev/null)
        set -l name (basename -- "$top")
        if contains -- "$name" $skip_names
            continue
        end
        if _is_protected_cache "$top"
            continue
        end
        set -l stats (_count_and_bytes_deep_older "$top")
        set total_count (math "$total_count + $stats[1]")
        set total_bytes (math "$total_bytes + $stats[2]")
    end

    test $total_count -gt 0; or return
    _print_preview "Generic ~/.cache cleanup $AGE_LABEL" $total_count $total_bytes

    if test $LIST_MATCHES -eq 1
        for top in (command find "$root" -mindepth 1 -maxdepth 1 -print 2>/dev/null)
            set -l name (basename -- "$top")
            contains -- "$name" $skip_names; and continue
            _is_protected_cache "$top"; and continue
            command find "$top" -mindepth 1 '(' -type f -o -type l ')' $AGE_ARGS -print 2>/dev/null
        end
    end

    if _confirm "Delete generic ~/.cache entries $AGE_LABEL (y/N)? "
        if test $DRY_RUN -eq 1
            _note "Would remove eligible ~/.cache entries"
        else
            for top in (command find "$root" -mindepth 1 -maxdepth 1 -print 2>/dev/null)
                set -l name (basename -- "$top")
                contains -- "$name" $skip_names; and continue
                _is_protected_cache "$top"; and continue
                _remove_old_files "$top"
            end
            _ok
        end
        _add_total $total_bytes
    else
        _note "Skipped"
    end
end

function _clean_mesa_shader_cache
    _clean_user_dirs \
        "Mesa shader cache $AGE_LABEL" \
        "Delete Mesa shader cache entries $AGE_LABEL (y/N)? " \
        $HOME/.cache/mesa_shader_cache \
        $HOME/.cache/mesa_shader_cache_db
end

function _clean_appimage_leftovers
    _clean_user_dirs \
        "AppImage cache $AGE_LABEL" \
        "Delete old AppImage cache entries (y/N)? " \
        $HOME/.cache/appimagekit
end

function _clean_crash_dumps
    set -l crash_dirs (command find $HOME/.config -maxdepth 3 -type d '(' -name Crashpad -o -name crash_reports -o -name 'Crash Reports' ')' 2>/dev/null)
    test (count $crash_dirs) -gt 0; or return

    set -l total_count 0
    set -l total_bytes 0
    for dir in $crash_dirs
        set -l stats (_count_and_bytes_deep_older "$dir")
        set total_count (math "$total_count + $stats[1]")
        set total_bytes (math "$total_bytes + $stats[2]")
    end
    test $total_count -gt 0; or return

    _print_preview "Crash dump files $AGE_LABEL" $total_count $total_bytes

    if test $LIST_MATCHES -eq 1
        for dir in $crash_dirs
            command find "$dir" -mindepth 1 '(' -type f -o -type l ')' $AGE_ARGS -print 2>/dev/null
        end
    end

    if _confirm "Delete crash dump files $AGE_LABEL (y/N)? "
        if test $DRY_RUN -eq 1
            _note "Would remove old crash dump files"
        else
            for dir in $crash_dirs
                _remove_old_files "$dir"
            end
            _ok
        end
        _add_total $total_bytes
    else
        _note "Skipped"
    end
end

function _clean_xsession_errors
    set -l file $HOME/.xsession-errors
    test -f "$file"; or return

    set -l sz (stat -c '%s' -- "$file" 2>/dev/null; or echo 0)
    test $sz -gt 0; or return

    # Age check (skip when --no-age)
    if test $NO_AGE -eq 0
        set -l mtime (stat -c '%Y' -- "$file" 2>/dev/null; or echo 0)
        set -l cutoff (math (date +%s)" - ($AGE_DAYS * 86400)")
        test $mtime -lt $cutoff; or return
