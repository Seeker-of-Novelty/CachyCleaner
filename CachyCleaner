    test -z "$pyc_bytes"; and set pyc_bytes 0

    set total_count (math "$total_count + $pyc_count")
    set total_bytes (math "$total_bytes + $pyc_bytes")

    test $total_count -gt 0; or return
    _print_preview "Python caches $AGE_LABEL" $total_count $total_bytes

    if _confirm "Delete old Python caches and __pycache__ directories (y/N)? "
        if test $DRY_RUN -eq 1
            _note "Would remove old Python caches and __pycache__ directories"
        else
            for dir in $HOME/.cache/uv $HOME/.cache/pip-tools $HOME/.pyenv/cache
