                if [[ $_mc_dry_run -eq 0 ]]; then
                    find /var/cache/pacman/pkg/ -maxdepth 1 -type d ! -name '*.*' -name "download-*" -exec sudo rm -rf {} + >/dev/null 2>&1
                fi
